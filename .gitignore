# Exclude common development files and folders
node_modules/
/vendor/
/composer.lock

*.log
*.sql
*.sql.gz
*.tar.gz
*.zip
wp-resolate*/
resolate*/
*.swp
*.swo
*.bak
*.bkp
*.back
*.tmp
*~
~$*
.~lock.*
.DS_Store
Thumbs.db
sftp-config.json

# Exclude specific editor/IDE files
/.idea/
.vscode/
.project
.settings/
*.sublime-workspace
*.sublime-project

# Exclude test-related files and directories
# /tests/
# /phpunit.xml
# /phpunit.xml.dist
.phpunit.result.cache
/behat.yml
.php-cs-fixer.cache

admin/vendor/tinybutstrong/tinybutstrong/examples/
admin/vendor/tinybutstrong/tinybutstrong/testunit/
admin/vendor/tinybutstrong/tinybutstrong/.gitattributes
admin/vendor/tinybutstrong/tinybutstrong/.gitignore

# LibreOffice WASM: the small glue scripts are committed; the large binaries
# (soffice.wasm/soffice.data, ~235 MB) are served from a CDN and never committed.
admin/vendor/libreoffice-converter/wasm/soffice.wasm
admin/vendor/libreoffice-converter/wasm/soffice.data
admin/vendor/libreoffice-converter/wasm/soffice.data.js.metadata

.env

wp/
wp-content/
wordpress-develop/
artifacts/

# Ignore Sass source maps
public/style/workarea/*.css.maptest-results/
test-results/*
.omc/
